name: Drupal CI

on:
  push:
    branches: [ master ]
  pull_request:

jobs:
  coding-standards:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Setup PHP
        uses: shivammathur/setup-php@v2
        with:
          php-version: 8.2
          extensions: mbstring, xml, gd, curl

      - name: Install Composer Dependencies
        run: composer install --no-interaction --prefer-dist

      - name: Run Drupal Coding Standards
        run: composer cs-check
